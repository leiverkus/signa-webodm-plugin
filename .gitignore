# .gitignore — Find-GCP/WebODM workflow
# ----------------------------------------------------------------------
# Field data, photogrammetry outputs and secrets never belong in the repo.
# Cf. .claudeignore (controls the Claude Code context) — intentionally
# overlapping, but strictly separate: this file controls git.
# ----------------------------------------------------------------------

# === Raw drone images & field data ===
fieldwork/*/raw/
**/raw/
*.JPG
*.jpg
*.JPEG
*.jpeg
*.DNG
*.dng
*.RAW
*.raw
*.NEF
*.CR2
*.ARW
*.tif
*.tiff
*.TIF
*.TIFF

# === Photogrammetry outputs ===
*.las
*.laz
*.ply
*.obj
*.fbx
*.3ds
*.glb
*.gltf
*.cog.tif
**/odm_orthophoto/
**/odm_dem/
**/odm_meshing/
**/odm_texturing*/
**/opensfm/
**/odm_filterpoints/
**/odm_georeferencing/
**/cameras.json
**/reconstruction.json

# === WebODM-ready (symlink folder) ===
**/webodm_ready/images/

# === GIS / geodata formats ===
*.gpkg
*.gpkg-journal
*.gpkg-wal
*.gpkg-shm
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.qix
*.sbn
*.sbx
*.mbtiles
*.pmtiles
*.aux.xml
*.ovr
*.qgz
# Exceptions: small test geometries allowed
!samples/*.gpkg
!tests/fixtures/*.geojson

# === Logs & reports (generated) ===
*.log
findgcp_*.log
gcp_report.txt
gcp_list.txt
!tests/fixtures/*gcp_list*.txt

# === Python artifacts ===
__pycache__/
*.py[cod]
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# === Secrets & credentials ===
*.env
.env*
!.env.example
*.key
*.pem
*.p12
secrets/
credentials/
.netrc

# === IDE & OS ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === Build output ===
dist/

# === Backups & archives ===
*.zip
*.tar
*.tar.gz
*.tgz
*.bak
*.old
tmp/
temp/
.cache/

# === Local agent/project context (never commit) ===
CLAUDE.md
CLAUDE-home.md
AGENTS.md
