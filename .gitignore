# .gitignore — Find-GCP/WebODM-Workflow
# ----------------------------------------------------------------------
# Felddaten, Photogrammetrie-Outputs und Secrets gehören nie ins Repo.
# Vgl. .claudeignore (steuert den Claude-Code-Kontext) — überlappt
# bewusst, ist aber strikt getrennt: dieses File steuert git.
# ----------------------------------------------------------------------

# === Drohnen-Rohbilder & Felddaten ===
fieldwork/*/raw/
**/raw/
*.JPG
*.jpg
*.JPEG
*.jpeg
*.DNG
*.dng
*.RAW
*.raw
*.NEF
*.CR2
*.ARW
*.tif
*.tiff
*.TIF
*.TIFF

# === Photogrammetrie-Outputs ===
*.las
*.laz
*.ply
*.obj
*.fbx
*.3ds
*.glb
*.gltf
*.cog.tif
**/odm_orthophoto/
**/odm_dem/
**/odm_meshing/
**/odm_texturing*/
**/opensfm/
**/odm_filterpoints/
**/odm_georeferencing/
**/cameras.json
**/reconstruction.json

# === WebODM-bereit (Symlink-Ordner) ===
**/webodm_ready/images/

# === GIS-/Geodatenformate ===
*.gpkg
*.gpkg-journal
*.gpkg-wal
*.gpkg-shm
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.qix
*.sbn
*.sbx
*.mbtiles
*.pmtiles
*.aux.xml
*.ovr
*.qgz
# Ausnahmen: schlanke Test-Geometrien erlaubt
!samples/*.gpkg
!tests/fixtures/*.geojson

# === Logs & Reports (generiert) ===
*.log
findgcp_*.log
gcp_report.txt
gcp_list.txt
!tests/fixtures/*gcp_list*.txt

# === Python-Artefakte ===
__pycache__/
*.py[cod]
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# === Secrets & Credentials ===
*.env
.env*
!.env.example
*.key
*.pem
*.p12
secrets/
credentials/
.netrc

# === IDE & OS ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === Backups & Archive ===
*.zip
*.tar
*.tar.gz
*.tgz
*.bak
*.old
tmp/
temp/
.cache/

# === Persönlicher globaler Claude-Kontext (nie committen) ===
CLAUDE-home.md
